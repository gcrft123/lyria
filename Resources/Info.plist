<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>DynamicIsland</string>
	<key>CFBundleDisplayName</key>
	<string>Dynamic Island</string>
	<key>CFBundleIdentifier</key>
	<string>com.dynamicisland.app</string>
	<key>CFBundleExecutable</key>
	<string>DynamicIsland</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<!-- Agent app: no Dock icon, no app menu. -->
	<key>LSUIElement</key>
	<true/>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- Required so macOS can prompt for permission to mirror & control Music. -->
	<key>NSAppleEventsUsageDescription</key>
	<string>Dynamic Island shows and controls what’s playing in Apple Music.</string>
	<!-- Required: IOBluetooth connect/disconnect notifications trip TCC and
	     hard-abort the app without this key, even for classic-Bluetooth APIs. -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Dynamic Island shows a banner when your Bluetooth devices connect or disconnect.</string>
	<!-- Required so macOS can prompt to tap the system audio mix, used to pulse
	     the island's glow in time with the music (Core Audio process tap). -->
	<key>NSAudioCaptureUsageDescription</key>
	<string>Dynamic Island listens to the audio mix so its glow can pulse in time with the music.</string>
	<!-- Required so macOS can prompt for Calendar access, used to show upcoming
	     events and a live activity for events starting soon. -->
	<key>NSCalendarsUsageDescription</key>
	<string>Dynamic Island shows your upcoming events and a live countdown for events starting soon.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Dynamic Island shows your upcoming events and a live countdown for events starting soon.</string>
	<!-- Required so macOS can prompt for location, used to show local weather. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Dynamic Island uses your location to show the local weather.</string>
	<key>NSLocationUsageDescription</key>
	<string>Dynamic Island uses your location to show the local weather.</string>
</dict>
</plist>
