# Build output
.build/
*.dmg

# Release archives (uploaded to GitHub Releases, never committed)
dist/

# Sparkle: vendor only the framework + CLI tools (needed to build & cut releases);
# skip the download tarball, debug symbols, and bundled test app (large, unused).
Vendor/*.tar.xz
Vendor/Sparkle-2.9.3/Symbols/
Vendor/Sparkle-2.9.3/Sparkle Test App.app/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Xcode / SwiftPM (in case a project is added later)
*.xcuserstate
xcuserdata/
.swiftpm/
DerivedData/

# Editor / tooling
.vscode/
*.swp
*~

# Local secrets / signing material (never commit these)
*.p12
*.cer
*.provisionprofile
.env

# Internal design / agent docs (kept out of the public repo)
CLAUDE.md
DESIGN_GUIDELINES.md
ONBOARDING_DESIGN.md
